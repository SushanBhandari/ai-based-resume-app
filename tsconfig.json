{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "types": ["nativewind/types", "expo", "react", "react-native"]
  },
  "include": [
    "app",
    "components",
    "context",
    "firebase",
    "utils",
    "global.d.ts",
    "nativewind-end.d.ts",
    "nativewind-env.d.ts",
    "App.tsx"
  ],
  "exclude": ["node_modules"]
}
